{
  "name": "skillhub-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "build:sizes": "next build --webpack && node scripts/report-route-sizes.mjs",
    "sizes": "node scripts/report-route-sizes.mjs",
    "analyze": "next experimental-analyze --port 4000",
    "analyze:webpack": "ANALYZE=true next build --webpack",
